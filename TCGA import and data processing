###building beta matrix for TCGA LUad
build_beta_matrix <- function(files) {
  stopifnot(length(files) > 0)
  
  ##read the first file to set thre probe order
  x1 <- read.delim(files[1], stringsAsFactors = FALSE)
  probes <- x1[[1]]
  mat <- matrix(as.numeric(x1[[2]]), ncol = 1)
  rownames(mat) <- probes 
  colnames(mat) <- sub("\\.methylation_array.*$", "", basename(files[1]))
  
  ##add the rest 
  for (i in 2:length(files)) {
    xi <- read.delim(files[i], stringsAsFactors = FALSE)
    
  ###Align by probe ID
    idx <- match(rownames(mat), xi[[1]])
    mat <- cbind(mat, as.numeric(xi[[2]][idx]))
    colnames(mat)[ncol(mat)] <- sub("\\.methylation_array.*$", "", basename(files[i]))
  if (i %% 10 == 0) message("Loaded", i, "/", length(files)) 
  }
  mat
}
build_and_save_project <- function(project, out_dir = "beta matrices") {
  dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)
  
  files <- list.files(
   file.path("GDCdata", project), 
      recursive = TRUE, 
      pattern = "level3betas\\.txt$",
      full.names = TRUE
  )
  message("\n==", project, "== files: ", length(files))
  if (length(files) == 0){
    warning("No beta files found for ", project, ". Skipping.")
  return(invisible(NULL))
  }
  beta <- build_beta_matrix(files)
  out_file <- file.path(out_dir, paste0(project, "_450_beta.rds"))
  saveRDS(beta, out_file)
  message("Saved: ", out_file, " dim=", paste(dim(beta), collapse = "x"))
  invisible(out_file)
}
